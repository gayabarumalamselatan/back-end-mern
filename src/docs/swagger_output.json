      },
      "CreateEventRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": ""
          },
          "banner": {
            "type": "string",
            "example": "fileUrl"
          },
          "category": {
            "type": "string",
            "example": "category ObjectID"
          },
          "description": {
            "type": "string",
            "example": ""
          },
          "startDate": {
            "type": "string",
            "example": "yyyy-mm-dd hh:mm:ss"
          },
          "endDate": {
            "type": "string",
            "example": "yyyy-mm-dd hh:mm:ss"
          },
          "location": {
            "type": "object",
            "properties": {
              "region": {
                "type": "string",
                "example": "region id"
              },
              "coordinates": {
                "type": "array",
                "example": [
                  0,
                  0
                ],
                "items": {
                  "type": "number"
                }
              },
              "address": {
                "type": "string",
                "example": ""
              }
            }
          },
          "isOnline": {
            "type": "boolean",
            "example": false
          },
          "isFeature": {
            "type": "boolean",
            "example": false
          },
          "isPublish": {
            "type": "boolean",
            "example": false
          }
        },
        "xml": {
          "name": "CreateEventRequest"
        }
      },
