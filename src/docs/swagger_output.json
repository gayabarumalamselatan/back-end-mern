            "example": "yoho2025"
          },
          "email": {
            "type": "string",
            "example": "yoho2025@yopmail.com"
          },
          "password": {
            "type": "string",
            "example": "Member2025!"
          },
          "confirmPassword": {
            "type": "string",
            "example": "Member2025!"
          }
        },
        "xml": {
          "name": "RegisterRequest"
        }
      },
